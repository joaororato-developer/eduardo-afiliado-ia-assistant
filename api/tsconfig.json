{
	"compilerOptions": {
	  "target": "es2020",
	  "module": "commonjs",
	  "moduleResolution": "node",
	  "rootDir": ".",
	  "outDir": "./dist",
	  "strict": true,
	  "esModuleInterop": true,
	  "skipLibCheck": true,
	  "sourceMap": true
	},
	"include": ["*.ts"],
	"exclude": ["node_modules", "dist"]
  }